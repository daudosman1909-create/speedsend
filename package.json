{
    "name": "bloom-monorepo-template",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo run dev",
        "dev:backend": "turbo run dev --filter=@bloom/backend",
        "dev:mobile": "turbo run dev --filter=@bloom/mobile",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "test": "turbo run test",
        "start": "cd apps/default && npm run start",
        "android": "cd apps/default && npm run android",
        "ios": "cd apps/default && npm run ios",
        "web": "cd apps/default && npm run web",
        "start:mobile": "cd apps/default && npm run start",
        "launch": "cd apps/default && npm run start"
    },
    "devDependencies": {
        "turbo": "^2.0.12"
    },
    "packageManager": "npm@10.0.0"
}
